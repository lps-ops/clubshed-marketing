---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'ClubShed | Football Equipment Tracker for Grassroots Clubs';
const description = 'Stop losing footballs, bibs, and kit. Track equipment, allocate to teams, generate grant audit reports. Free for one team.';

const kitItems = [
  '⚽ Match Ball #024',
  '🦺 Bibs Set Orange',
  '🔶 Cones (20)',
  '🧤 GK Gloves L',
  '👕 U14 Match Kit',
  '🎒 Training Bag #07',
  '⚽ Training Ball #112',
  '🩹 First Aid Kit',
  '📣 Whistle',
  '🅿️ Pump',
];
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__grid-overlay"></div>
    </div>

    <div class="container hero__inner">
      <div class="hero__copy">
        <span class="tag rise rise-1">
          <span class="tag__dot"></span>
          Made for grassroots football
        </span>
        <h1 class="display hero__h1 rise rise-2">
          <span class="hero__line">Stop losing</span>
          <span class="hero__line">your <span class="hero__accent">footballs.</span></span>
        </h1>
        <p class="hero__lede rise rise-3">
          ClubShed is the equipment tracker built for the volunteer running your club out of a kit cupboard. Know what you own, who has it, and when it should come back.
        </p>
        <div class="hero__cta rise rise-4">
          <a href="https://app.clubshed.pro/signup" class="btn btn--accent btn--lg">
            Start free
            <span class="btn__arrow">→</span>
          </a>
          <a href="#preview" class="btn btn--ghost btn--lg">See it in action</a>
        </div>
        <div class="hero__trust rise rise-5">
          <div class="hero__trust-item">
            <span class="check">+</span>
            <span>Free forever for one team</span>
          </div>
          <div class="hero__trust-item">
            <span class="check">+</span>
            <span>No card required</span>
          </div>
          <div class="hero__trust-item">
            <span class="check">+</span>
            <span>5-minute setup</span>
          </div>
        </div>
      </div>

      <div class="hero__visual rise rise-3" aria-hidden="true">
        <div class="scoreboard">
          <div class="scoreboard__head">
            <div class="scoreboard__indicator">
              <span class="scoreboard__pulse"></span>
              LIVE
            </div>
            <div class="scoreboard__title">Kit Cupboard</div>
            <div class="scoreboard__date">Today</div>
          </div>
          <div class="scoreboard__body">
            <div class="ticker-row ticker-row--out">
              <div class="ticker-row__icon">⚽</div>
              <div class="ticker-row__main">
                <div class="ticker-row__label">Match Ball #024</div>
                <div class="ticker-row__sub">Out · Coach Marco · U14</div>
              </div>
              <div class="ticker-row__status">OUT</div>
            </div>
            <div class="ticker-row ticker-row--in">
              <div class="ticker-row__icon">🦺</div>
              <div class="ticker-row__main">
                <div class="ticker-row__label">Bibs Set Orange</div>
                <div class="ticker-row__sub">In storage · Cupboard 1</div>
              </div>
              <div class="ticker-row__status">IN</div>
            </div>
            <div class="ticker-row ticker-row--late">
              <div class="ticker-row__icon">🔶</div>
              <div class="ticker-row__main">
                <div class="ticker-row__label">Cones (20)</div>
                <div class="ticker-row__sub">3 days overdue · Coach Sara</div>
              </div>
              <div class="ticker-row__status">LATE</div>
            </div>
            <div class="ticker-row ticker-row--in">
              <div class="ticker-row__icon">🧤</div>
              <div class="ticker-row__main">
                <div class="ticker-row__label">GK Gloves Size L</div>
                <div class="ticker-row__sub">In storage · U16 bag</div>
              </div>
              <div class="ticker-row__status">IN</div>
            </div>
          </div>
          <div class="scoreboard__foot">
            <div class="scoreboard__stat">
              <span class="scoreboard__stat-num">47</span>
              <span class="scoreboard__stat-label">In</span>
            </div>
            <div class="scoreboard__stat">
              <span class="scoreboard__stat-num">12</span>
              <span class="scoreboard__stat-label">Out</span>
            </div>
            <div class="scoreboard__stat scoreboard__stat--alert">
              <span class="scoreboard__stat-num">2</span>
              <span class="scoreboard__stat-label">Late</span>
            </div>
          </div>
        </div>

        <div class="floating-card floating-card--qr">
          <div class="floating-card__qr">
            <svg viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg">
              <rect width="21" height="21" fill="#1a2e1f"/>
              <g fill="#f4f1ea">
                <rect x="1" y="1" width="7" height="7"/>
                <rect x="13" y="1" width="7" height="7"/>
                <rect x="1" y="13" width="7" height="7"/>
                <rect x="3" y="3" width="3" height="3" fill="#1a2e1f"/>
                <rect x="15" y="3" width="3" height="3" fill="#1a2e1f"/>
                <rect x="3" y="15" width="3" height="3" fill="#1a2e1f"/>
                <rect x="10" y="2" width="1" height="1"/>
                <rect x="10" y="4" width="1" height="1"/>
                <rect x="10" y="6" width="1" height="1"/>
                <rect x="11" y="3" width="1" height="1"/>
                <rect x="11" y="5" width="1" height="1"/>
                <rect x="10" y="10" width="1" height="1"/>
                <rect x="12" y="10" width="1" height="1"/>
                <rect x="14" y="10" width="1" height="1"/>
                <rect x="16" y="10" width="1" height="1"/>
                <rect x="18" y="10" width="1" height="1"/>
                <rect x="11" y="12" width="1" height="1"/>
                <rect x="13" y="12" width="1" height="1"/>
                <rect x="15" y="12" width="1" height="1"/>
                <rect x="17" y="12" width="1" height="1"/>
                <rect x="10" y="14" width="1" height="1"/>
                <rect x="14" y="14" width="1" height="1"/>
                <rect x="18" y="14" width="1" height="1"/>
                <rect x="12" y="16" width="1" height="1"/>
                <rect x="16" y="16" width="1" height="1"/>
                <rect x="10" y="18" width="1" height="1"/>
                <rect x="14" y="18" width="1" height="1"/>
                <rect x="18" y="18" width="1" height="1"/>
              </g>
            </svg>
          </div>
          <div class="floating-card__id">CS-024</div>
        </div>
      </div>
    </div>

    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        {[...kitItems, ...kitItems].map((item) => (
          <span class="marquee__item">
            {item}
            <span class="marquee__sep">/</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCT PREVIEW -->
  <section id="preview" class="preview reveal">
    <div class="container">
      <div class="preview__header">
        <span class="tag">The product</span>
        <h2 class="display">An inventory that fits in your hand,<br />not in a binder.</h2>
        <p class="preview__lede">Built mobile-first because the kit cupboard isn't where laptops live. Coaches check gear in and out in two taps. You see the whole club from your phone.</p>
      </div>

      <div class="preview__phone-wrap">
        <div class="callout callout--1">
          <div class="callout__num">01</div>
          <h3>Scan, don't search</h3>
          <p>Print a QR sticker for every bag and bin. Scan with your phone. Check in or out in seconds.</p>
        </div>

        <div class="preview__phone">
          <div class="preview__phone-notch"></div>
          <div class="preview__phone-screen">
            <div class="phone-app">
              <div class="phone-app__header">
                <div>
                  <div class="phone-app__hi">Hi Coach</div>
                  <div class="phone-app__club">Hortaleza FC</div>
                </div>
                <div class="phone-app__avatar">C</div>
              </div>

              <div class="phone-app__stats">
                <div class="phone-stat">
                  <div class="phone-stat__num">61</div>
                  <div class="phone-stat__label">Items</div>
                </div>
                <div class="phone-stat">
                  <div class="phone-stat__num">12</div>
                  <div class="phone-stat__label">Out</div>
                </div>
                <div class="phone-stat phone-stat--alert">
                  <div class="phone-stat__num">2</div>
                  <div class="phone-stat__label">Late</div>
                </div>
              </div>

              <div class="phone-app__section-title">Recent activity</div>

              <div class="phone-feed">
                <div class="phone-feed__item">
                  <div class="phone-feed__dot phone-feed__dot--out"></div>
                  <div class="phone-feed__body">
                    <div class="phone-feed__main"><strong>Marco</strong> took 6 balls</div>
                    <div class="phone-feed__time">U14 training · 2h ago</div>
                  </div>
                </div>
                <div class="phone-feed__item">
                  <div class="phone-feed__dot phone-feed__dot--in"></div>
                  <div class="phone-feed__body">
                    <div class="phone-feed__main"><strong>Sara</strong> returned bibs</div>
                    <div class="phone-feed__time">U16 match · 5h ago</div>
                  </div>
                </div>
                <div class="phone-feed__item">
                  <div class="phone-feed__dot phone-feed__dot--late"></div>
                  <div class="phone-feed__body">
                    <div class="phone-feed__main">GK gloves <strong>overdue</strong></div>
                    <div class="phone-feed__time">Out 8 days · Coach Tom</div>
                  </div>
                </div>
              </div>

              <div class="phone-scan-btn">
                <span class="phone-scan-icon">⊞</span>
                Scan kit code
              </div>
            </div>
          </div>
        </div>

        <div class="preview__callouts-right">
          <div class="callout callout--2">
            <div class="callout__num">02</div>
            <h3>Know who has what</h3>
            <p>Every coach, every team, every item. Tap a name to see what they're holding.</p>
          </div>
          <div class="callout callout--3">
            <div class="callout__num">03</div>
            <h3>Catch the leaks</h3>
            <p>Reminders go out automatically when gear is overdue. No more polite WhatsApp begging.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="problem reveal">
    <div class="container">
      <div class="problem__header">
        <span class="tag tag--filled">The honest truth</span>
        <h2 class="display">If your kit man retired tomorrow,<br />would anyone know where anything is?</h2>
      </div>

      <div class="scoreboard-stats">
        <div class="scoreboard-stats__row">
          <div class="scoreboard-stats__label">Avg replacement cost per season</div>
          <div class="scoreboard-stats__num">€1,400</div>
          <div class="scoreboard-stats__bar">
            <span style="width: 70%;"></span>
          </div>
        </div>
        <div class="scoreboard-stats__row">
          <div class="scoreboard-stats__label">Clubs running on a spreadsheet, or nothing</div>
          <div class="scoreboard-stats__num">6 / 10</div>
          <div class="scoreboard-stats__bar">
            <span style="width: 60%;"></span>
          </div>
        </div>
        <div class="scoreboard-stats__row">
          <div class="scoreboard-stats__label">Clubs seeing equipment costs rise this year</div>
          <div class="scoreboard-stats__num">87%</div>
          <div class="scoreboard-stats__bar">
            <span style="width: 87%;"></span>
          </div>
        </div>
        <div class="scoreboard-stats__row">
          <div class="scoreboard-stats__label">Footballs the average club replaces per season</div>
          <div class="scoreboard-stats__num">18</div>
          <div class="scoreboard-stats__bar">
            <span style="width: 45%;"></span>
          </div>
        </div>
      </div>

      <div class="problem__quote">
        <div class="problem__quote-mark">"</div>
        <blockquote>
          Coach Marco took six balls to U14 training on Tuesday. Four came back. By Saturday nobody could remember whose bag the other two were in. By November we'd bought twelve new balls we didn't need.
        </blockquote>
        <cite>— Every grassroots club, every season</cite>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="how reveal">
    <div class="container">
      <div class="how__header">
        <span class="tag">How it works</span>
        <h2 class="display">Three things.<br />That's the product.</h2>
      </div>

      <div class="how__steps">
        <div class="how__step">
          <div class="how__num">01</div>
          <div class="how__connector"></div>
          <h3 class="display">Log what you own</h3>
          <p>Add items with a photo, a category, and a location. Balls, bibs, cones, GK gloves, first aid kits, match kit. Scan a QR sticker to add it even faster. No setup wizards, no imports.</p>
        </div>
        <div class="how__step">
          <div class="how__num">02</div>
          <div class="how__connector"></div>
          <h3 class="display">Hand it out</h3>
          <p>When a coach takes equipment to training, log who took what. Tap two buttons. ClubShed remembers it's out with them and when it's due back.</p>
        </div>
        <div class="how__step">
          <div class="how__num">03</div>
          <h3 class="display">Get it back</h3>
          <p>Automatic reminders when gear is overdue. A clean audit log so you know exactly when six balls turned into four. End the November mystery.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="features reveal">
    <div class="container">
      <div class="features__header">
        <span class="tag tag--accent">What's in the box</span>
        <h2 class="display">Built for kit cupboards,<br />not boardrooms.</h2>
      </div>

      <div class="features__grid">
        <div class="feature">
          <div class="feature__icon">📷</div>
          <h3>Photo-first inventory</h3>
          <p>Every item has a photo. Find the orange bibs in seconds, not by digging through 47 generic entries.</p>
        </div>
        <div class="feature">
          <div class="feature__icon">🏷️</div>
          <h3>QR code stickers</h3>
          <p>Print a QR sticker for every bag and bin. Scan to check in or out. Works on any phone, no extra app for coaches.</p>
        </div>
        <div class="feature">
          <div class="feature__icon">👥</div>
          <h3>Team allocations</h3>
          <p>Assign equipment to teams, age groups, or individual coaches. See at a glance what U14 has out versus U16.</p>
        </div>
        <div class="feature">
          <div class="feature__icon">⏰</div>
          <h3>Return reminders</h3>
          <p>Set a due-back date. Automatic email and WhatsApp-ready reminder text when gear is overdue.</p>
        </div>
        <div class="feature">
          <div class="feature__icon">📋</div>
          <h3>The audit log</h3>
          <p>Every check-in, check-out, and transfer is logged. When something disappears, you have the trail.</p>
        </div>
        <div class="feature">
          <div class="feature__icon">📊</div>
          <h3>End-of-season report</h3>
          <p>A clean PDF for your committee: what you own, what you lost, what to replace. Funding applications get easier.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BUILT BY -->
  <section class="builder reveal">
    <div class="container">
      <div class="builder__grid">
        <div>
          <span class="tag">Built by</span>
          <h2 class="display">Someone who co-founded a football club.</h2>
        </div>
        <div class="builder__copy">
          <p>ClubShed isn't built by a software company that decided football was a market. It's built by someone who co-founded HVV Football Factory and watched the same equipment disappear every season for years. Every feature is something a grassroots volunteer actually asked for.</p>
          <p>If you have a feature idea, you can email me directly. I'll probably reply within a day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS / RELATED -->
  <section class="related reveal">
    <div class="container">
      <div class="related__header">
        <span class="tag">Read more</span>
        <h2 class="display">Practical guides for grassroots clubs.</h2>
      </div>
      <div class="related__grid">
        <a href="/blog/end-of-season-equipment-audit/" class="related__card">
          <span class="related__tag">Audit</span>
          <h3>How to run an end-of-season equipment audit</h3>
          <p>The step-by-step process for closing out your season, marking what's lost, and producing a grant-ready report.</p>
          <span class="related__more">Read the guide →</span>
        </a>
        <a href="/blog/football-foundation-grants-equipment-grassroots/" class="related__card">
          <span class="related__tag">Grants</span>
          <h3>Football Foundation grants for equipment</h3>
          <p>What grants your club can apply for in 2026, what your application needs to include, and what tends to get rejected.</p>
          <span class="related__more">Read the guide →</span>
        </a>
        <a href="/compare/spond/" class="related__card">
          <span class="related__tag">Comparison</span>
          <h3>ClubShed vs Spond for equipment tracking</h3>
          <p>An honest comparison. Spond does fixtures and member admin well. ClubShed does equipment. Use both.</p>
          <span class="related__more">See the comparison →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta reveal">
    <div class="container">
      <div class="final-cta__inner">
        <h2 class="display">Your bibs are not lost.<br />They're just untracked.</h2>
        <p>Start free with one team. Upgrade to paid (€15.99/month) when you're ready to track your whole club.</p>
        <div class="final-cta__actions">
          <a href="https://app.clubshed.pro/signup" class="btn btn--accent btn--lg">Start free</a>
          <a href="/blog/grassroots-football-equipment-guide/" class="btn btn--ghost btn--lg">Read the guide first</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
  }
</script>

<style>
  :global(.btn--lg) {
    padding: 1.05rem 1.8rem;
    font-size: 1rem;
  }

  :global(.btn__arrow) {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  :global(.btn:hover .btn__arrow) {
    transform: translateX(4px);
  }

  /* HERO */
  .hero {
    padding: clamp(3rem, 6vw, 5rem) 0 0;
    position: relative;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(28, 28, 28, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(28, 28, 28, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at 50% 30%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, black 30%, transparent 80%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 4rem;
    align-items: center;
    padding-bottom: 4rem;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 960px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .hero__copy .tag {
    margin-bottom: 1.75rem;
    background: var(--chalk-warm);
  }

  .tag__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--grass-bright);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero__h1 {
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.9;
  }

  .hero__line {
    display: block;
  }

  .hero__accent {
    color: var(--kit-orange);
    position: relative;
    display: inline-block;
  }

  .hero__accent::after {
    content: '';
    position: absolute;
    left: -2%;
    right: -2%;
    bottom: 0.08em;
    height: 0.12em;
    background: var(--kit-orange);
    opacity: 0.2;
    transform: skewY(-1deg);
  }

  .hero__lede {
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    margin: 1.75rem 0 2.25rem;
    color: var(--asphalt);
    max-width: 50ch;
    line-height: 1.55;
  }

  .hero__cta {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-bottom: 2.25rem;
  }

  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 1.75rem;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .check {
    color: var(--grass-bright);
    font-weight: 700;
    font-family: var(--font-mono);
  }

  /* SCOREBOARD */
  .hero__visual {
    position: relative;
    height: 520px;
  }

  @media (max-width: 960px) {
    .hero__visual {
      height: auto;
      min-height: 460px;
      max-width: 440px;
      margin: 0 auto;
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .hero__visual {
      min-height: 420px;
      max-width: 100%;
      padding-right: 1rem;
    }
  }

  .scoreboard {
    position: absolute;
    inset: 0;
    background: var(--pitch-deep);
    border: 2px solid var(--asphalt);
    border-radius: var(--radius);
    box-shadow: 12px 12px 0 var(--kit-orange);
    color: var(--chalk);
    overflow: hidden;
    transform: rotate(-1.5deg);
  }

  @media (max-width: 520px) {
    .scoreboard {
      transform: rotate(-1deg);
      box-shadow: 6px 6px 0 var(--kit-orange);
      inset: 0 2rem 0 0;
    }
  }

  .scoreboard__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(244, 241, 234, 0.1);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .scoreboard__indicator {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--kit-orange);
    font-weight: 600;
  }

  .scoreboard__pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--kit-orange);
    animation: pulse 1.5s ease-in-out infinite;
    box-shadow: 0 0 8px var(--kit-orange);
  }

  .scoreboard__title {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--chalk);
  }

  .scoreboard__date {
    opacity: 0.5;
  }

  .scoreboard__body {
    padding: 0.5rem;
  }

  .ticker-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 0.85rem;
    border-bottom: 1px solid rgba(244, 241, 234, 0.06);
    animation: ticker-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @media (max-width: 520px) {
    .ticker-row {
      gap: 0.55rem;
      padding: 0.65rem 0.65rem;
    }
  }

  .ticker-row:nth-child(1) { animation-delay: 0.4s; }
  .ticker-row:nth-child(2) { animation-delay: 0.55s; }
  .ticker-row:nth-child(3) { animation-delay: 0.7s; }
  .ticker-row:nth-child(4) { animation-delay: 0.85s; }

  @keyframes ticker-in {
    from { opacity: 0; transform: translateX(-12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .ticker-row__icon {
    font-size: 1.4rem;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    background: rgba(244, 241, 234, 0.06);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .ticker-row__icon {
      width: 32px;
      height: 32px;
      font-size: 1.15rem;
    }
  }

  .ticker-row__main {
    flex: 1;
    min-width: 0;
  }

  .ticker-row__label {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 520px) {
    .ticker-row__label {
      font-size: 0.95rem;
    }
  }

  .ticker-row__sub {
    font-size: 0.78rem;
    opacity: 0.6;
    font-family: var(--font-mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 520px) {
    .ticker-row__sub {
      font-size: 0.7rem;
    }
  }

  .ticker-row__status {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.55rem;
    border-radius: var(--radius-sm);
  }

  .ticker-row--out .ticker-row__status {
    background: rgba(232, 85, 42, 0.15);
    color: var(--kit-orange);
    border: 1px solid rgba(232, 85, 42, 0.4);
  }

  .ticker-row--in .ticker-row__status {
    background: rgba(74, 143, 94, 0.15);
    color: var(--grass-bright);
    border: 1px solid rgba(74, 143, 94, 0.4);
  }

  .ticker-row--late .ticker-row__status {
    background: rgba(214, 40, 40, 0.2);
    color: #ff6b6b;
    border: 1px solid rgba(214, 40, 40, 0.5);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .scoreboard__foot {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: rgba(0, 0, 0, 0.25);
    border-top: 1px solid rgba(244, 241, 234, 0.08);
  }

  .scoreboard__stat {
    text-align: center;
    padding: 1rem 0.5rem;
    border-right: 1px solid rgba(244, 241, 234, 0.08);
  }

  .scoreboard__stat:last-child {
    border-right: none;
  }

  .scoreboard__stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--chalk);
  }

  .scoreboard__stat--alert .scoreboard__stat-num {
    color: #ff6b6b;
  }

  .scoreboard__stat-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    margin-top: 0.25rem;
  }

  .floating-card {
    position: absolute;
    background: var(--chalk);
    border: 2px solid var(--asphalt);
    border-radius: var(--radius);
    padding: 0.85rem;
    box-shadow: 4px 4px 0 var(--pitch);
    z-index: 2;
    transform: rotate(6deg);
    animation: float-card 4s ease-in-out infinite;
  }

  @keyframes float-card {
    0%, 100% { transform: rotate(6deg) translateY(0); }
    50% { transform: rotate(6deg) translateY(-6px); }
  }

  .floating-card--qr {
    bottom: -2rem;
    right: -1.5rem;
  }

  @media (max-width: 520px) {
    .floating-card--qr {
      bottom: -1rem;
      right: 0.5rem;
      padding: 0.6rem;
    }

    .floating-card--qr .floating-card__qr {
      width: 64px;
      height: 64px;
    }
  }

  .floating-card__qr {
    width: 80px;
    height: 80px;
    margin-bottom: 0.5rem;
  }

  .floating-card__qr svg {
    width: 100%;
    height: 100%;
    border-radius: var(--radius-sm);
  }

  .floating-card__id {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* MARQUEE */
  .marquee {
    border-top: 2px solid var(--asphalt);
    border-bottom: 2px solid var(--asphalt);
    background: var(--asphalt);
    color: var(--chalk);
    padding: 0.85rem 0;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .marquee__track {
    display: flex;
    gap: 2rem;
    width: max-content;
    animation: marquee 40s linear infinite;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    white-space: nowrap;
  }

  .marquee__sep {
    color: var(--kit-orange);
    font-weight: 700;
  }

  /* PRODUCT PREVIEW */
  .preview {
    padding: clamp(5rem, 9vw, 8rem) 0;
    background: var(--chalk);
  }

  .preview__header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .preview__header .tag {
    margin-bottom: 1.5rem;
  }

  .preview__lede {
    margin: 1.25rem auto 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  .preview__phone-wrap {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (max-width: 960px) {
    .preview__phone-wrap {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .preview__phone {
    width: 300px;
    height: 600px;
    background: var(--asphalt);
    border-radius: 38px;
    padding: 12px;
    box-shadow:
      0 0 0 2px var(--asphalt),
      20px 20px 0 var(--kit-orange);
    position: relative;
    justify-self: center;
  }

  @media (max-width: 960px) {
    .preview__phone {
      margin: 0 auto;
      order: 1;
    }
  }

  @media (max-width: 520px) {
    .preview__phone {
      width: 280px;
      height: 560px;
      box-shadow:
        0 0 0 2px var(--asphalt),
        10px 10px 0 var(--kit-orange);
    }
  }

  .preview__phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 22px;
    background: var(--asphalt);
    border-radius: 0 0 12px 12px;
    z-index: 2;
  }

  .preview__phone-screen {
    width: 100%;
    height: 100%;
    background: var(--chalk);
    border-radius: 26px;
    overflow: hidden;
    position: relative;
  }

  .phone-app {
    padding: 2.25rem 1.25rem 1.25rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .phone-app__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .phone-app__hi {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.15rem;
  }

  .phone-app__club {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1;
  }

  .phone-app__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--pitch);
    color: var(--chalk);
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .phone-app__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .phone-stat {
    background: var(--chalk-warm);
    border: 1.5px solid var(--asphalt);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.5rem;
    text-align: center;
  }

  .phone-stat__num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
  }

  .phone-stat__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
    margin-top: 0.3rem;
  }

  .phone-stat--alert {
    background: rgba(232, 85, 42, 0.1);
    border-color: var(--kit-orange);
  }

  .phone-stat--alert .phone-stat__num {
    color: var(--kit-orange);
  }

  .phone-app__section-title {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.55;
    margin-top: 0.5rem;
  }

  .phone-feed {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .phone-feed__item {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.6rem;
    background: var(--chalk-warm);
    border-radius: var(--radius-sm);
  }

  .phone-feed__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 0.4rem;
    flex-shrink: 0;
  }

  .phone-feed__dot--out { background: var(--kit-orange); }
  .phone-feed__dot--in { background: var(--grass-bright); }
  .phone-feed__dot--late {
    background: #d62828;
    animation: pulse 1.5s ease-in-out infinite;
  }

  .phone-feed__main {
    font-size: 0.85rem;
    line-height: 1.3;
  }

  .phone-feed__time {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    opacity: 0.55;
    margin-top: 0.2rem;
  }

  .phone-scan-btn {
    background: var(--kit-orange);
    color: var(--chalk);
    text-align: center;
    padding: 0.85rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .phone-scan-icon {
    font-size: 1.1rem;
  }

  .preview__callouts-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 960px) {
    .preview__callouts-right {
      order: 2;
    }
  }

  .callout {
    padding: 1.25rem;
    background: var(--chalk-warm);
    border: 1.5px solid var(--asphalt);
    border-radius: var(--radius);
    max-width: 280px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .callout:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--kit-orange);
  }

  .callout--1 {
    justify-self: end;
    margin-bottom: 0;
  }

  @media (max-width: 960px) {
    .callout {
      max-width: none;
      justify-self: stretch;
    }
    .callout--1 {
      order: 2;
    }
  }

  .callout__num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--kit-orange);
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .callout h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
  }

  .callout p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* PROBLEM */
  .problem {
    background: var(--chalk-warm);
    border-top: 2px solid var(--asphalt);
    border-bottom: 2px solid var(--asphalt);
  }

  .problem__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .problem__header .tag {
    margin-bottom: 1.5rem;
  }

  .problem__header h2 {
    max-width: 22ch;
    margin: 0 auto;
  }

  .scoreboard-stats {
    max-width: 820px;
    margin: 0 auto 4rem;
    background: var(--asphalt);
    color: var(--chalk);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: 12px 12px 0 var(--kit-orange);
  }

  @media (max-width: 520px) {
    .scoreboard-stats {
      padding: 1.25rem;
      box-shadow: 6px 6px 0 var(--kit-orange);
    }
  }

  .scoreboard-stats__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(244, 241, 234, 0.1);
  }

  .scoreboard-stats__row:last-child {
    border-bottom: none;
  }

  .scoreboard-stats__label {
    font-family: var(--font-body);
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .scoreboard-stats__num {
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--kit-orange);
    letter-spacing: 0.01em;
  }

  .scoreboard-stats__bar {
    grid-column: 1 / -1;
    height: 4px;
    background: rgba(244, 241, 234, 0.08);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.75rem;
  }

  .scoreboard-stats__bar span {
    display: block;
    height: 100%;
    background: var(--kit-orange);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.is-visible .scoreboard-stats__bar span {
    transform: scaleX(1);
  }

  .problem__quote {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    background: var(--chalk);
    border-left: 4px solid var(--kit-orange);
    position: relative;
  }

  .problem__quote-mark {
    position: absolute;
    top: -1rem;
    left: 1.5rem;
    font-family: var(--font-display);
    font-size: 6rem;
    color: var(--kit-orange);
    line-height: 1;
  }

  .problem__quote blockquote {
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    font-style: italic;
    line-height: 1.55;
    margin-bottom: 1rem;
  }

  .problem__quote cite {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    font-style: normal;
    letter-spacing: 0.05em;
  }

  /* HOW IT WORKS */
  .how__header {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .how__header .tag {
    margin-bottom: 1.5rem;
  }

  .how__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    position: relative;
  }

  @media (max-width: 880px) {
    .how__steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  .how__step {
    position: relative;
  }

  .how__num {
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--kit-orange);
    line-height: 1;
    margin-bottom: 1rem;
    display: block;
  }

  .how__connector {
    position: absolute;
    top: 1.8rem;
    left: 4.5rem;
    right: -3rem;
    height: 2px;
    background: repeating-linear-gradient(
      to right,
      var(--asphalt) 0,
      var(--asphalt) 8px,
      transparent 8px,
      transparent 16px
    );
  }

  @media (max-width: 880px) {
    .how__connector { display: none; }
  }

  .how__step h3 {
    margin-bottom: 0.75rem;
  }

  .how__step p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* FEATURES */
  .features {
    background: var(--pitch-deep);
    color: var(--chalk);
  }

  .features__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .features__header .tag {
    margin-bottom: 1.5rem;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid rgba(244, 241, 234, 0.15);
  }

  @media (max-width: 880px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }

  .feature {
    padding: 2.5rem 2rem;
    border-right: 1px solid rgba(244, 241, 234, 0.15);
    border-bottom: 1px solid rgba(244, 241, 234, 0.15);
    transition: background 0.2s ease;
  }

  .feature:hover {
    background: rgba(232, 85, 42, 0.08);
  }

  .feature:nth-child(3n) {
    border-right: none;
  }

  @media (max-width: 880px) {
    .feature:nth-child(3n) { border-right: 1px solid rgba(244, 241, 234, 0.15); }
    .feature:nth-child(2n) { border-right: none; }
  }

  .feature__icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .feature h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
  }

  .feature p {
    font-size: 0.92rem;
    opacity: 0.75;
    line-height: 1.55;
  }

  /* BUILDER */
  .builder__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 760px) {
    .builder__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .builder__grid .tag {
    margin-bottom: 1rem;
  }

  .builder__copy p {
    margin-bottom: 1rem;
    color: var(--muted);
  }

  /* RELATED CARDS */
  .related {
    padding: clamp(4rem, 8vw, 7rem) 0;
    background: var(--chalk-warm);
    border-top: 2px solid var(--asphalt);
  }

  .related__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .related__header .tag {
    margin-bottom: 1rem;
  }

  .related__header h2 {
    max-width: 22ch;
    margin: 0 auto;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1080px;
    margin: 0 auto;
  }

  @media (max-width: 880px) {
    .related__grid {
      grid-template-columns: 1fr;
    }
  }

  .related__card {
    display: block;
    background: var(--chalk);
    border: 2px solid var(--asphalt);
    border-radius: var(--radius);
    padding: 1.75rem;
    text-decoration: none;
    color: var(--asphalt);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .related__card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--asphalt);
  }

  .related__tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kit-orange);
    margin-bottom: 0.75rem;
    display: inline-block;
  }

  .related__card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    letter-spacing: 0.01em;
  }

  .related__card p {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .related__more {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--kit-orange);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* FINAL CTA */
  .final-cta {
    background: var(--kit-orange);
    color: var(--chalk);
    position: relative;
    overflow: hidden;
  }

  .final-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 40px,
      rgba(244, 241, 234, 0.04) 40px,
      rgba(244, 241, 234, 0.04) 80px
    );
    pointer-events: none;
  }

  .final-cta__inner {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }

  .final-cta h2 {
    margin-bottom: 1.5rem;
  }

  .final-cta p {
    font-size: 1.05rem;
    margin: 0 auto 2rem;
    max-width: 50ch;
  }

  .final-cta__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

