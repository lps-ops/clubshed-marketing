const description = "Step-by-step audit playbook for grassroots clubs. Count what survived, mark lost items, produce a grant-ready report. Written by a club that does this every May.";
const publishDate = '2026-05-21';
const updateDate = '2026-05-21';
---

<BaseLayout title={title} description={description} type="article" publishDate={publishDate} updateDate={updateDate}>
